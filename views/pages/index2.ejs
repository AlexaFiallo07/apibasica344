<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
</head>
<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
       <div class="jumbotron">
           <h1>clientes</h1>
           <table id="tablita" class="table table-dark table-hover" border="2px">
               <thead>
                   <th>Nombre</th>
                   <th>Email</th>
                   <th>Telefono</th>
               </thead>
               <tbody >
                   <% clientes.forEach(function(cliente) { %>
                   <tr>
                       <td><%=cliente.nombre%></td>
                       <td><%=cliente.email%></td>
                       <td><%=cliente.telefono%></td>
                   </tr>
               <% }); %>
               </tbody>


           </table>
          
           <ul>
              
           </ul>


         
       </div>
   </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>
</html>