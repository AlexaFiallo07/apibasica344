{
  "name": "ejercicios-productos",
  "version": "1.0.0",
  "description": "API de productos para ejercicios con Express y MongoDB",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "seed": "node seed.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "models/**/*.js",
      "config/**/*.js"
    ]
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "ejs": "^6.0.1",
    "express": "^4.22.2",
    "mongoose": "^7.8.9"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14"
  }
}
